                                <div class="col-md-4 border-right">
                                    <i class="fa fa-user mt-2 h4" aria-hidden="true"></i>
                                </div>
                                <div class="col-md-8">
                                    <span class="text-white font-weight-bold">Patient
                                    </span>
                                    <br>
                                    <span class="small-font">Add New<span>
                                </div>
                            </div>
                        </a>
                    </div>


                    <div id="divExpense" runat="server" class="col-md-2 mr-2 ml-2 bg-blueGradient">
                        <a href="../Site/frmExpense.aspx" class="text-white">
