                                <div class="col-md-4 border-right mt-1">
                                    <i class="fa fa-signal h4" aria-hidden="true"></i>
                                </div>
                                <div class="col-md-8">
                                    <span class="text-white font-weight-bold">Expense
                                    </span>
                                    <br>
                                    <span class="small-font">View Expense<span>
                                </div>
                            </div>
                        </a>
                    </div>



                    <div id="divCash" runat="server" class="col-md-2 mr-2 ml-2 bg-blueGradient">
                        <a href="../Site/frmCash.aspx" class="text-white">
                            <div class="row  mt-2">
                                <div class="col-md-4 border-right mt-1">
                                    <i class="fa fa-cubes h4" aria-hidden="true"></i>
                                </div>
                                <div class="col-md-8">
                                    <span class="text-white font-weight-bold">Cash Summary
                                    </span>
                                    <br>
                                    <span class="small-font">View Summary<span>
                                </div>
                            </div>
                        </a>
                    </div>





                </div>
            </div>
        </div>

        <div class="body-content">
            <asp:ContentPlaceHolder ID="MainContent" runat="server">
            </asp:ContentPlaceHolder>
        </div>

        <div class="lab-footer bg-blueGradient">
            <div class="container">
                <div class="row">
                    <div class="col-md-6 text-center text-md-start">
                        <p class="mb-0">Pathoxperts ® AL RAZI Lab Management. © 2019-2025. All Rights Reserved.</p>
                    </div>

                </div>
            </div>
        </div>
       
        <!-- jQuery (Only one version) -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<!-- Bootstrap Dependencies -->
<script src="../Site/WebTemplate/js/popper.min.js"></script>
<script src="../Site/WebTemplate/js/bootstrap.min.js"></script>

<!-- FontAwesome -->
<script src="../Site/WebTemplate/js/all.min.js"></script>

<!-- Select2 (Only one source) -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.13/js/select2.min.js"></script>

<!-- DataTables (must load AFTER jQuery) -->
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

<!-- Other Scripts -->
<script src="../Site/WebTemplate/js/custom.js"></script>
<script src="../Site/WebTemplate/js/validator.js"></script>

<script>
    $(document).ready(function () {
        // Initialize Select2
        $(".mySelect2").select2({
    width: '100%'  // Enforces full width
});


        // Show only the first tab by default
        $(".tab-contents").hide();
        $(".tab-contents:first").show();
        $("#tab-button a").removeClass("active");
        $("#tab-button li:first a").addClass("active");

        // Tab click handler
        $("#tab-button a").on("click", function (e) {
            e.preventDefault();
            $(".tab-contents").hide();
            $($(this).attr("href")).show();
            $("#tab-button a").removeClass("active");
            $(this).addClass("active");
        });
    });

    // Handle UpdatePanel partial postback
    Sys.WebForms.PageRequestManager.getInstance().add_endRequest(function () {
        $(".mySelect2").select2();

        $("#tab-button a").off("click").on("click", function (e) {
            e.preventDefault();
            $(".tab-contents").hide();
            $($(this).attr("href")).show();
            $("#tab-button a").removeClass("active");
            $(this).addClass("active");
        });
    });
</script>

    </form>


</body>
</html>