                                    <i class="fa fa-bars h4" aria-hidden="true"></i>
                                    <br>
                                    Accounts
                                </a>
                            </div>

                            <div id="divManagement" runat="server" class="col-md-2 customGrey-btn p-1 mr-2 ml-2 text-center rounded-top">
                                <a href="../Site/frmManagement.aspx" class="text-dark font-weight-bold">
                                    <i class="fa fa-users h4" aria-hidden="true"></i>
                                    <br>
                                    Management
                                </a>
